        <h4>Front-end Development</h4>
        <p>Building scalable, modular, performance optimised responsive websites and applications.</p>
      </div>
    </div>
    <a class="btn-primary" href="/resume.pdf">View résumé</a>
  </div>
</div>

<div class="site-main-section panel-glacier-gray-xxlight" id="work">
  <header class="container pad-one-col">
    <h2>My Work</h2>
    <p class="lede">Due to contractual obligations I'm unable to share all work online. <a href="mailto:damianwalsh@me.com">Get in touch</a> to discuss further examples.</p>
  </header>
  <div class="work-grid">
    <% blog.articles[0...10].each do |article| %>
      <div class="work-grid-item">
        <a href="<%= article.url %>" class="card">
          <img src="https://wit.wurfl.io/https://damianwalsh.me/images/<%= article.data.cover_image %>" alt="<%= article.title %>" class="card-image">
          <div class="card-info">
            <h3 class="card-title"><%= article.data.title %></h3>
            <p class="card-description"><%= article.data.description %></p>
            <p class="card-cta btn-secondary">
              <i class="icon-keyboard-arrow-right"></i>
              <b>More</b>
            </p>
          </div>
        </a>
      </div>
    <% end %>
  </div>
</div>

<div class="site-main-section panel-aquamarine-light">
  <div class="container pad-one-col">
    <blockquote class="blockquote-fancy">
      <p>Damian is an exceptional talent producing top notch, on-brand website design. He keeps up with front-end development trends and produces lean, efficient code.</p>
      <footer>
        <p><small>Darren Ferguson. Director, Moriyama</small></p>
      </footer>
    </blockquote>
  </div>
</div>

